# Lingua Nova — environment template.
# Copy to .env and adjust. NEVER commit a real .env.

# App
APP_NAME=Lingua Nova
# PHASE: 1 = text MVP, 2 = voice (future)
PHASE=1

# Local LLM (Ollama). Keep local-first / privacy-first by default.
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b-instruct-q4_K_M

# Database. SQLite for local dev; swap for a postgresql:// URL in production.
# Leave unset to default to data/lingua.db (see core/config.py).
# DATABASE_URL=sqlite:///./data/lingua.db

# Optional: CEFR scale (comma separated).
CEFR_LEVELS=A1,A2,B1,B2,C1,C2
